# Backend secrets — copy to secrets.env, never commit secrets.env to git.
# Postgres reachable via host.docker.internal (docker bridge gateway).
DATABASE_URL=postgresql://sonatum_user:CHANGE_ME@host.docker.internal:5432/sonatum_music?schema=public
TELEGRAM_BOT_TOKEN=CHANGE_ME
ALLOWED_ADMIN_TG_ID=CHANGE_ME

# Frontend public envs (passed through compose, optional override here)
NEXT_PUBLIC_API_URL=https://sonatum-music.ru
NEXT_PUBLIC_TELEGRAM_BOT_NAME=sonatumbot
